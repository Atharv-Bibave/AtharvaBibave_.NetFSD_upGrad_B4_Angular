@model EventManagementSystem.AppUI.Models.RegisterViewModel

@{
    ViewData["Title"] = "Create Account";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">

        <div class="text-center mb-3">
            <a href="/Participant/Login" class="text-muted small">&larr; Back to Sign In</a>
        </div>
        <div class="card shadow">
            <div class="card-header bg-warning text-dark text-center">
                <h5 class="mb-0">&#128221; Create Your EMS Account</h5>
                <small class="opacity-75">upGrad Virtual Event Management System</small>
            </div>
            <div class="card-body">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="EmailId" class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                        <input asp-for="EmailId" class="form-control" placeholder="your@email.com" autocomplete="email" />
                        <span asp-validation-for="EmailId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                        <input asp-for="UserName" class="form-control" placeholder="Your full name" />
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold">Password <span class="text-danger">*</span></label>
                        <input asp-for="Password" class="form-control" placeholder="6–20 characters" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold">Confirm Password <span class="text-danger">*</span></label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat your password" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-warning w-100 fw-bold">Register</button>
                </form>

                <p class="mt-3 text-center text-muted small">
                    Already have an account? <a href="/Participant/Login">Login here</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
