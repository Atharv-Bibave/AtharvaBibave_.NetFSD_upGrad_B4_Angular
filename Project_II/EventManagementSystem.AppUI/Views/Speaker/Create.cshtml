@model EventManagementSystem.AppUI.Models.SpeakerViewModel

@{
    ViewData["Title"] = "Add Speaker";
}

<h2>Add Speaker</h2>

<div class="row">
    <div class="col-md-4">
        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 @(ViewData.ModelState.IsValid ? "d-none" : "")"></div>

            <div class="mb-3">
                <label asp-for="SpeakerName" class="form-label fw-semibold">Speaker Name <span class="text-danger">*</span></label>
                <input asp-for="SpeakerName" class="form-control" placeholder="Full name" />
                <span asp-validation-for="SpeakerName" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-success">Save Speaker</button>
            <a asp-controller="Speaker" asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
