@model IEnumerable<EventManagementSystem.DataAccessLayer.Models.SpeakersDetails>

@{
    ViewData["Title"] = "Manage Speakers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Speakers</h2>
    <div class="d-flex gap-2">
        <a asp-controller="Speaker" asp-action="Create" class="btn btn-primary">+ Add Speaker</a>
        <a asp-controller="Admin" asp-action="SpeakerAssignments" class="btn btn-outline-info">Speaker Assignments</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No speakers found. <a asp-controller="Speaker" asp-action="Create">Add the first speaker</a>.</div>
}
else
{
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Speaker Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @{ int i = 1; }
            @foreach (var item in Model)
            {
                <tr>
                    <td>@(i++)</td>
                    <td>@item.SpeakerName</td>
                    <td>
                        <a asp-controller="Speaker" asp-action="Delete" asp-route-id="@item.SpeakerId"
                           class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
