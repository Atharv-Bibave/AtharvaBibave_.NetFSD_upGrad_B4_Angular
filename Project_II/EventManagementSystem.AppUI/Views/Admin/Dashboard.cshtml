@model EventManagementSystem.AppUI.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="mb-4">Admin Dashboard</h2>

<div class="row mb-4 g-3">
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card text-white bg-primary h-100">
            <div class="card-body text-center">
                <div class="fs-2 fw-bold">@Model.TotalEvents</div>
                <div class="small">Total Events</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card text-white bg-success h-100">
            <div class="card-body text-center">
                <div class="fs-2 fw-bold">@Model.ActiveEvents</div>
                <div class="small">Active</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card text-white bg-secondary h-100">
            <div class="card-body text-center">
                <div class="fs-2 fw-bold">@Model.InactiveEvents</div>
                <div class="small">Inactive</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card text-white bg-info h-100">
            <div class="card-body text-center">
                <div class="fs-2 fw-bold">@Model.TotalSessions</div>
                <div class="small">Total Sessions</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card text-white bg-warning h-100">
            <div class="card-body text-center">
                <div class="fs-2 fw-bold">@Model.AssignedSessions</div>
                <div class="small">Speaker Assigned</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4 col-lg-2">
        <div class="card text-white bg-danger h-100">
            <div class="card-body text-center">
                <div class="fs-2 fw-bold">@(Model.TotalSessions - Model.AssignedSessions)</div>
                <div class="small">Unassigned</div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4 g-3">
    <div class="col-md-4">
        <div class="card h-100 border-primary">
            <div class="card-body">
                <h5 class="card-title">📅 Manage Events</h5>
                <p class="card-text text-muted small">Add, edit, toggle status, and delete events.</p>
                <a asp-controller="Admin" asp-action="Index" class="btn btn-primary btn-sm">Go to Events</a>
                <a asp-controller="Admin" asp-action="Create" class="btn btn-outline-primary btn-sm ms-1">+ New Event</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-info">
            <div class="card-body">
                <h5 class="card-title">📋 Manage Sessions</h5>
                <p class="card-text text-muted small">Add sessions under events and assign speakers.</p>
                <a asp-controller="Session" asp-action="Index" class="btn btn-info btn-sm">Go to Sessions</a>
                <a asp-controller="Session" asp-action="Create" class="btn btn-outline-info btn-sm ms-1">+ New Session</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-warning">
            <div class="card-body">
                <h5 class="card-title">🎤 Manage Speakers</h5>
                <p class="card-text text-muted small">Add or remove speakers and assign them to sessions.</p>
                <a asp-controller="Speaker" asp-action="Index" class="btn btn-warning btn-sm">Go to Speakers</a>
                <a asp-controller="Admin" asp-action="SpeakerAssignments" class="btn btn-outline-warning btn-sm ms-1">Assignments</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-secondary">
            <div class="card-body">
                <h5 class="card-title">👥 Participants</h5>
                <p class="card-text text-muted small">View participant registrations and filter by event.</p>
                <a asp-controller="Admin" asp-action="Participants" class="btn btn-secondary btn-sm">View Participants</a>
            </div>
        </div>
    </div>
</div>

@* Event + Sessions table — same as original *@
@if (!Model.Events.Any())
{
    <div class="alert alert-info">No events found. <a asp-controller="Admin" asp-action="Create">Create your first event</a>.</div>
}
else
{
    @foreach (var ev in Model.Events)
    {
        var sessions = Model.SessionsByEvent.TryGetValue(ev.EventId, out var s) ? s : new();

        <div class="card mb-3 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>@ev.EventName</strong>
                    <span class="badge bg-secondary ms-2">@ev.EventCategory</span>
                    <span class="badge @(ev.Status == "Active" ? "bg-success" : "bg-secondary") ms-1">@ev.Status</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted small">📅 @ev.EventDate.ToShortDateString()</span>
                    <a asp-controller="Admin" asp-action="Details" asp-route-id="@ev.EventId"
                       class="btn btn-sm btn-outline-secondary">Details</a>
                    <a asp-controller="Admin" asp-action="Edit" asp-route-id="@ev.EventId"
                       class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-controller="Session" asp-action="Index" asp-route-eventId="@ev.EventId"
                       class="btn btn-sm btn-outline-info">Sessions</a>
                    <form method="post"
                          asp-controller="Admin" asp-action="ToggleStatus" asp-route-id="@ev.EventId"
                          style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="btn btn-sm @(ev.Status == "Active" ? "btn-outline-secondary" : "btn-outline-success")">
                            @(ev.Status == "Active" ? "Deactivate" : "Activate")
                        </button>
                    </form>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(ev.Description))
            {
                <div class="px-3 pt-2 text-muted small">@ev.Description</div>
            }

            <div class="card-body p-0">
                @if (!sessions.Any())
                {
                    <div class="px-3 py-2 text-muted small fst-italic">
                        No sessions yet.
                        <a asp-controller="Session" asp-action="Create" class="ms-1">Add a session</a>
                    </div>
                }
                else
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Session Title</th>
                                <th>Start</th>
                                <th>End</th>
                                <th>Speaker</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var session in sessions.OrderBy(s => s.SessionStart))
                            {
                                <tr>
                                    <td class="ps-3">@session.SessionTitle</td>
                                    <td class="small">@session.SessionStart.ToString("dd MMM, HH:mm")</td>
                                    <td class="small">@session.SessionEnd.ToString("dd MMM, HH:mm")</td>
                                    <td>
                                        @if (session.Speaker != null)
                                        {
                                            <span class="badge bg-info text-dark">🎤 @session.Speaker.SpeakerName</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-secondary border">Unassigned</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="Session" asp-action="AssignSpeaker" asp-route-id="@session.SessionId"
                                           class="btn btn-outline-secondary"
                                           style="font-size:0.75rem; padding:1px 6px;">
                                            Assign Speaker
                                        </a>
                                        <a asp-controller="Session" asp-action="Edit" asp-route-id="@session.SessionId"
                                           class="btn btn-outline-warning ms-1"
                                           style="font-size:0.75rem; padding:1px 6px;">
                                            Edit
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }
}
