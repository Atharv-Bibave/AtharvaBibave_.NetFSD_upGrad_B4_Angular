@model EventManagementSystem.DataAccessLayer.Models.EventDetails

@{
    ViewData["Title"] = "Event Details - " + Model.EventName;
}

<div class="mb-3">
    <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back to Events</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <span class="badge bg-primary me-2">@Model.EventCategory</span>
            <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-secondary")">@Model.Status</span>
        </div>
        <span class="text-muted small">📅 @Model.EventDate.ToString("dddd, dd MMMM yyyy")</span>
    </div>
    <div class="card-body">
        <h3 class="card-title">@Model.EventName</h3>
        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <p class="card-text lead text-muted">@Model.Description</p>
        }
        else
        {
            <p class="text-muted fst-italic">No description provided.</p>
        }
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-controller="Admin" asp-action="Edit" asp-route-id="@Model.EventId"
           class="btn btn-warning btn-sm">✏️ Edit Event</a>

        <form method="post" asp-controller="Admin" asp-action="ToggleStatus" asp-route-id="@Model.EventId"
              style="display:inline">
            @Html.AntiForgeryToken()
            <button type="submit"
                    class="btn btn-sm @(Model.Status == "Active" ? "btn-outline-secondary" : "btn-outline-success")">
                @(Model.Status == "Active" ? "Deactivate" : "Activate")
            </button>
        </form>

        <a asp-controller="Session" asp-action="Index" asp-route-eventId="@Model.EventId"
           class="btn btn-info btn-sm">📋 Manage Sessions</a>
    </div>
</div>

<h4 class="mb-3">Sessions for this Event</h4>

@if (Model.Sessions == null || !Model.Sessions.Any())
{
    <div class="alert alert-info">
        No sessions yet.
        <a asp-controller="Session" asp-action="Create">Add a session</a> to get started.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Session Title</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Speaker</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var session in Model.Sessions.OrderBy(s => s.SessionStart))
                {
                    <tr>
                        <td>@session.SessionTitle</td>
                        <td class="small">@session.SessionStart.ToString("dd MMM yyyy, HH:mm")</td>
                        <td class="small">@session.SessionEnd.ToString("dd MMM yyyy, HH:mm")</td>
                        <td>
                            @if (session.Speaker != null)
                            {
                                <span class="badge bg-info text-dark">🎤 @session.Speaker.SpeakerName</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-secondary border">Unassigned</span>
                            }
                        </td>
                        <td class="text-nowrap">
                            <a asp-controller="Session" asp-action="Edit" asp-route-id="@session.SessionId"
                               class="btn btn-sm btn-warning">Edit</a>
                            <a asp-controller="Session" asp-action="AssignSpeaker" asp-route-id="@session.SessionId"
                               class="btn btn-sm btn-outline-info ms-1">Assign Speaker</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
