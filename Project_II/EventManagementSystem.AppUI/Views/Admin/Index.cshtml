@model IEnumerable<EventManagementSystem.DataAccessLayer.Models.EventDetails>

@{
    ViewData["Title"] = "Manage Events";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Manage Events</h2>
    <a asp-controller="Admin" asp-action="Create" class="btn btn-primary">+ Add Event</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No events found. <a asp-controller="Admin" asp-action="Create">Create your first event</a>.</div>
}
else
{
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.EventName</td>
                    <td>@item.EventCategory</td>
                    <td>@item.EventDate.ToShortDateString()</td>
                    <td>
                        <span class="badge @(item.Status == "Active" ? "bg-success" : "bg-secondary")">
                            @item.Status
                        </span>
                    </td>
                    <td>
                        <div class="d-flex flex-wrap gap-1">
                            <a asp-controller="Admin" asp-action="Details" asp-route-id="@item.EventId"
                               class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-controller="Admin" asp-action="Edit" asp-route-id="@item.EventId"
                               class="btn btn-sm btn-warning">Edit</a>
                            <a asp-controller="Session" asp-action="Index" asp-route-eventId="@item.EventId"
                               class="btn btn-sm btn-info">Sessions</a>

                            <form method="post"
                                  asp-controller="Admin" asp-action="ToggleStatus" asp-route-id="@item.EventId"
                                  style="display:inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm @(item.Status == "Active" ? "btn-secondary" : "btn-success")">
                                    @(item.Status == "Active" ? "Deactivate" : "Activate")
                                </button>
                            </form>

                            <a asp-controller="Admin" asp-action="Delete" asp-route-id="@item.EventId"
                               class="btn btn-sm btn-danger">Delete</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
