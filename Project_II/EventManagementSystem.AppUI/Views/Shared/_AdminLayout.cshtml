<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel | EMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM"
          crossorigin="anonymous" />
</head>
<body class="bg-light">

    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-controller="Admin" asp-action="Dashboard">⚙️ EMS Admin</a>
            <div class="d-flex flex-wrap gap-1">
                @if (Context.Session.GetString("AdminEmail") != null)
                {
                    <a class="btn btn-outline-light btn-sm" asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                    <a class="btn btn-outline-light btn-sm" asp-controller="Admin" asp-action="Index">Events</a>
                    <a class="btn btn-outline-light btn-sm" asp-controller="Session" asp-action="Index">Sessions</a>
                    <a class="btn btn-outline-light btn-sm" asp-controller="Speaker" asp-action="Index">Speakers</a>
                    <a class="btn btn-outline-info btn-sm" asp-controller="Admin" asp-action="SpeakerAssignments">Speaker Assignments</a>
                    <a class="btn btn-outline-light btn-sm" asp-controller="Admin" asp-action="Participants">Participants</a>
                    <a class="btn btn-danger btn-sm" asp-controller="Admin" asp-action="Logout">Logout</a>
                }
                else
                {
                    <a class="btn btn-outline-light btn-sm" asp-controller="Home" asp-action="Index">← Public Site</a>
                }
            </div>
        </div>
    </nav>

    <div class="container mt-3 mb-5">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                ✅ @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                ❌ @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz"
            crossorigin="anonymous"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
