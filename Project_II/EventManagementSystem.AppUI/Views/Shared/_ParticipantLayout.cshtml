<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM"
          crossorigin="anonymous" />
</head>
<body>

    <nav class="navbar navbar-light bg-white border-bottom shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/">🗓️ EMS</a>
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <a class="btn btn-outline-secondary btn-sm" asp-controller="Home" asp-action="Index">Home</a>
                <a class="btn btn-outline-primary btn-sm" asp-controller="Participant" asp-action="Explore">Explore Events</a>
                @{
                    var participantEmail = Context.Session.GetString("UserEmail");
                    var adminEmail       = Context.Session.GetString("AdminEmail");
                }
                @if (participantEmail != null)
                {
                    <span class="btn btn-outline-dark btn-sm disabled">
                        👤 @Context.Session.GetString("UserName")
                    </span>
                    <a class="btn btn-outline-secondary btn-sm" asp-controller="Participant" asp-action="Dashboard">Dashboard</a>
                    <a class="btn btn-primary btn-sm" asp-controller="Participant" asp-action="RegisteredEvents">My Events</a>
                    <a class="btn btn-outline-info btn-sm" asp-controller="Participant" asp-action="MySessions">My Sessions</a>
                    <a class="btn btn-outline-danger btn-sm" asp-controller="Participant" asp-action="Logout">Logout</a>
                }
                else
                {
                    <a class="btn btn-success btn-sm" asp-controller="Participant" asp-action="Login">Login</a>
                    <a class="btn btn-warning btn-sm" asp-controller="Participant" asp-action="Register">Register</a>
                    @if (adminEmail == null)
                    {
                        <a class="btn btn-dark btn-sm" asp-controller="Admin" asp-action="Login">⚙️ Admin</a>
                    }
                    else
                    {
                        <a class="btn btn-dark btn-sm" asp-controller="Admin" asp-action="Dashboard">⚙️ Admin Panel</a>
                    }
                }
            </div>
        </div>
    </nav>

    <div class="container mt-3 mb-5">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                ✅ @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                ❌ @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz"
            crossorigin="anonymous"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
