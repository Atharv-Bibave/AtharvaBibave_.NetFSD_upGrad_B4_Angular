@model IEnumerable<EventManagementSystem.DataAccessLayer.Models.SessionInfo>

@{
    ViewData["Title"] = "Manage Sessions";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Manage Sessions</h2>
        @if (ViewBag.FilterEventName != null)
        {
            <small class="text-muted">
                Filtered by event: <strong>@ViewBag.FilterEventName</strong>
                <a asp-controller="Session" asp-action="Index" class="ms-2 text-danger small">Clear filter</a>
            </small>
        }
    </div>
    <a asp-controller="Session" asp-action="Create" class="btn btn-primary">+ Add Session</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No sessions found. <a asp-controller="Session" asp-action="Create">Add the first session.</a>
    </div>
}
else
{
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Event</th>
                <th>Speaker</th>
                <th>Start</th>
                <th>End</th>
                <th>URL</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.SessionTitle</td>
                    <td>@item.Event?.EventName</td>
                    <td>
                        @if (item.Speaker != null)
                        {
                            <span class="badge bg-info text-dark">@item.Speaker.SpeakerName</span>
                        }
                        else
                        {
                            <span class="text-muted small">Not assigned</span>
                        }
                    </td>
                    <td class="small">@item.SessionStart.ToString("dd MMM yyyy HH:mm")</td>
                    <td class="small">@item.SessionEnd.ToString("dd MMM yyyy HH:mm")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.SessionUrl))
                        {
                            <a href="@item.SessionUrl" target="_blank" class="btn btn-sm btn-outline-info">🔗 Link</a>
                        }
                        else
                        {
                            <span class="text-muted small">—</span>
                        }
                    </td>
                    <td class="text-nowrap">
                        <a asp-controller="Session" asp-action="Edit" asp-route-id="@item.SessionId"
                           class="btn btn-sm btn-warning">Edit</a>
                        <a asp-controller="Session" asp-action="AssignSpeaker" asp-route-id="@item.SessionId"
                           class="btn btn-sm btn-info ms-1">Assign Speaker</a>
                        <a asp-controller="Session" asp-action="Delete" asp-route-id="@item.SessionId"
                           class="btn btn-sm btn-danger ms-1">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
