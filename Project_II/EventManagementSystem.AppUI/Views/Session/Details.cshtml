@model EventManagementSystem.DataAccessLayer.Models.SessionInfo

@{
    ViewData["Title"] = Model.SessionTitle;
    Layout = "~/Views/Shared/_ParticipantLayout.cshtml";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        @if (Model.Event != null)
        {
            <li class="breadcrumb-item">
                <a asp-controller="Session" asp-action="ViewSessions" asp-route-eventId="@Model.EventId">
                    @Model.Event.EventName
                </a>
            </li>
        }
        <li class="breadcrumb-item active">@Model.SessionTitle</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">📋 @Model.SessionTitle</h4>
            </div>
            <div class="card-body">

                @if (Model.Event != null)
                {
                    <p class="mb-2">
                        <span class="fw-semibold">🗓 Event:</span>
                        <a asp-controller="Session" asp-action="ViewSessions" asp-route-eventId="@Model.EventId">
                            @Model.Event.EventName
                        </a>
                        <span class="badge bg-light text-dark ms-2">@Model.Event.EventCategory</span>
                    </p>
                }

                <p class="mb-2">
                    <span class="fw-semibold">🕐 Time:</span>
                    @Model.SessionStart.ToString("dd MMM yyyy, HH:mm") – @Model.SessionEnd.ToString("HH:mm")
                    <span class="text-muted small ms-1">
                        (@((int)(Model.SessionEnd - Model.SessionStart).TotalMinutes) min)
                    </span>
                </p>

                @if (Model.Speaker != null)
                {
                    <p class="mb-2">
                        <span class="fw-semibold">🎤 Speaker:</span>
                        <span class="badge bg-info text-dark">@Model.Speaker.SpeakerName</span>
                    </p>
                }
                else
                {
                    <p class="mb-2 text-muted">
                        <span class="fw-semibold">🎤 Speaker:</span> To be announced
                    </p>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <hr />
                    <h6 class="fw-semibold mb-2">About this Session</h6>
                    <p class="text-secondary">@Model.Description</p>
                }

            </div>

            @if (!string.IsNullOrWhiteSpace(Model.SessionUrl))
            {
                <div class="card-footer">
                    <a href="@Model.SessionUrl" target="_blank" class="btn btn-primary w-100">
                        🔗 Join Session
                    </a>
                </div>
            }
        </div>

        <div class="mt-3">
            @if (Model.Event != null)
            {
                <a asp-controller="Session" asp-action="ViewSessions" asp-route-eventId="@Model.EventId"
                   class="btn btn-outline-secondary btn-sm">
                    ← Back to Sessions for @Model.Event.EventName
                </a>
            }
            else
            {
                <a href="/" class="btn btn-outline-secondary btn-sm">← Back to Events</a>
            }
        </div>
    </div>
</div>
